{
  "name": "metis",
  "version": "0.1.0",
  "description": "Per-project skill manager for Claude Code — install, organize, and link skills with symlinks",
  "private": true,
  "type": "module",
  "bin": {
    "metis": "./bin/metis"
  },
  "scripts": {
    "build": "tsc && node scripts/build-bin.mjs",
    "dev": "npx tsx src/cli.ts",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "typecheck": "npx tsc --noEmit"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "gray-matter": "^4.0.3",
    "simple-git": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
