#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
ENTRY_POINT="$PROJECT_DIR/src/cli.ts"
if [[ ! -f "$ENTRY_POINT" ]]; then
  echo "Error: Entry point not found at $ENTRY_POINT" >&2
  exit 1
fi
# Switch to project dir so npx has a valid CWD regardless of terminal state
cd "$PROJECT_DIR"
# Uses tsx for development; compile with tsc for production and use node dist/cli.js
exec npx tsx "$ENTRY_POINT" "$@"
